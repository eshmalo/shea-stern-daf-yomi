# --- Heavy self-hosted media (the ~60GB+ audio/video library) ---
# Regenerate locally with build/selfhost_media.py; never commit the binaries.
media/*.mp3
media/*.mp4
media/*.m4a
media/*.webm
media/*.mov
# ...but DO keep the manifest (small index of what's been self-hosted).
!media/manifest.json

# --- Content that IS preserved in git (explicit, for clarity) ---
# data/daf/*.json   (native daf text — kept)
# data/library.json (catalog snapshot fallback — kept)
# data/content.json (editable content — kept)

# --- OS / editor junk ---
.DS_Store
Thumbs.db
*.swp
*~

# --- Python build/cache ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# --- Secrets: cloud storage / CDN credentials (NEVER commit) ---
build/cloud.config
.env

# --- Media pipeline temp files ---
media/.tmp/
media/.stream_tmp/

# --- Logs / scratch ---
*.log

# daily-run marker for update_all.py (once/day Sefaria gate)
build/.sefaria_last_run

# --- logo_audit caches + scratch (regenerable); keep the tool + the JSON deliverables ---
build/.logo_score_cache.json
build/.logo_res_cache.json
build/logo_audit/_frames/
build/logo_audit/template.npy
build/logo_audit/*.png
